{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/test",
      "dest": "/api/test.mjs"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/handler.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
