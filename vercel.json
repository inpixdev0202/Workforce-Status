{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/test",
      "destination": "/client/api/test.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/client/api/index.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/client/dist/index.html"
    }
  ]
}
