{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/test",
      "dest": "/client/api/test.mjs"
    },
    {
      "src": "/api/(.*)",
      "dest": "/client/api/handler.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/client/dist/index.html"
    }
  ]
}
